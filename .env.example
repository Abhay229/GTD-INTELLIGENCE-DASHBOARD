# Copy this file to .env and fill in your own values.
# .env is gitignored - never commit real API keys.

# Get a free API key at https://openrouter.ai (no credit card required)
OPENROUTER_API_KEY=

# Optional overrides - defaults are set in agent/llm_client.py
# Free, tool-calling-capable models on OpenRouter as of mid-2026
# (always double check openrouter.ai/models filtered to Price: Free,
# since the free-tier lineup rotates over time)
OPENROUTER_MODEL=qwen/qwen3-coder:free
OPENROUTER_FALLBACK_MODEL=openrouter/free
